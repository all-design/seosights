// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Existing Models ────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String?
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?
  subscriptionStatus    String    @default("trial") // trial | active | past_due | canceled
  tier                  String    @default("trial") // trial | starter | pro | managed

  // ─── Agency White-Label Branding (Pro+ feature) ──────────────────────
  agencyName            String?   // e.g. "Apex Digital Agency"
  agencyLogoUrl         String?   // e.g. "https://cdn.apex.com/logo.png"
  agencyPrimaryColor    String    @default("#10b981") // HEX code for CSS — default emerald
  agencySecondaryColor  String    @default("#6B7280") // HEX code for CSS — default gray

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // ─── Affiliate System ────────────────────────────────────────────────
  referredByAffiliateId String?  // ID of the affiliate who referred this user

  analyses        Analysis[]
  projects        Project[]
  webhooks        WebhookConfig[]
  alerts          VisibilityAlert[]
  tokenUsageLogs  TokenUsageLog[]
  affiliate       Affiliate?
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  website   String?
  createdAt DateTime @default(now())
}

// ─── New Models ─────────────────────────────────────────────────────

model Analysis {
  id        String   @id @default(cuid())
  url       String
  domain    String
  market    String   @default("Global")
  status    String   @default("pending") // pending | running | completed | failed
  mode      String   @default("auto-pilot") // auto-pilot | co-pilot
  userId    String?
  projectId String?
  result    String?  // JSON string of full analysis result
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User?           @relation(fields: [userId], references: [id])
  project        Project?        @relation(fields: [projectId], references: [id])
  agentLogs      AgentLog[]
  approvals      Approval[]
  tokenUsageLogs TokenUsageLog[]

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([domain])
}

model AgentLog {
  id           String    @id @default(cuid())
  analysisId   String
  agentId      String    // e.g. "master-director", "keyword-researcher"
  agentName    String    // e.g. "Master Director"
  action       String    // what the agent is doing, e.g. "Scanning Perplexity mentions..."
  status       String    // running | completed | failed
  tokensUsed   Int       @default(0)
  costUsd      Float     @default(0)
  model        String    @default("default")
  result       String?   // JSON string of agent result
  error        String?   // error message if failed
  startedAt    DateTime
  completedAt  DateTime?

  analysis     Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([agentId])
  @@index([status])
}

model Approval {
  id               String    @id @default(cuid())
  analysisId       String
  agentId          String    // which agent produced the action
  agentName        String
  actionType       String    // e.g. "meta-tag-change", "content-publish", "robots-update"
  actionDescription String   // what the agent wants to do
  actionData       String    // JSON string with the proposed change details
  status           String    @default("pending") // pending | approved | rejected | expired
  reviewedAt       DateTime?
  reviewedBy       String?   // user who reviewed
  createdAt        DateTime  @default(now())

  analysis         Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([status])
  @@index([actionType])
}

model AgentPrompt {
  id                 String   @id @default(cuid())
  agentId            String   @unique // e.g. "master-director"
  agentName          String
  systemPrompt       String   // the system prompt text
  userPromptTemplate String   // the user prompt template with {{variables}}
  model              String   @default("default") // primary LLM model
  fallbackModel      String?  // fallback model if primary fails
  isActive           Boolean  @default(true)
  version            Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([agentId])
  @@index([isActive])
}

model TokenUsage {
  id                String   @id @default(cuid())
  date              DateTime // the day this record is for
  agentId           String
  agentName         String
  model             String
  totalInputTokens  Int      @default(0)
  totalOutputTokens Int      @default(0)
  totalTokens       Int      @default(0)
  estimatedCostUsd  Float    @default(0)
  apiCalls          Int      @default(0)
  failures          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([date, agentId, model])
  @@index([date])
  @@index([agentId])
  @@index([model])
}

model WebhookConfig {
  id              String    @id @default(cuid())
  userId          String
  type            String    // "slack" | "discord" | "custom"
  url             String    // webhook URL
  events          String    // JSON array of event types to listen for
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isActive])
}

model VisibilityAlert {
  id        String   @id @default(cuid())
  userId    String
  domain    String   // the domain being monitored
  alertType String   // "citation_drop" | "ai_overview_lost" | "bot_blocked" | "score_change"
  severity  String   @default("warning") // info | warning | critical
  message   String
  data      String?  // JSON with alert details
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([domain])
  @@index([alertType])
  @@index([severity])
  @@index([isRead])
}

// ─── Enterprise SaaS Models ─────────────────────────────────────────

model Project {
  id            String    @id @default(cuid())
  userId        String
  url           String    // the website being tracked
  domain        String    // extracted domain
  targetMarket  String    @default("global")
  executionMode String    @default("co-pilot") // co-pilot | auto-pilot
  lastAnalysisAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses       Analysis[]
  tokenUsageLogs TokenUsageLog[]

  @@index([userId])
  @@index([domain])
}

// ─── Affiliate / Reseller System ──────────────────────────────────────

model Affiliate {
  id                    String    @id @default(cuid())
  userId                String    @unique
  affiliateCode         String    @unique  // e.g. "marko10", "seomaster"
  totalReferredActive   Int       @default(0) // count of currently active paid subscribers
  totalEarningsUsd      Float     @default(0) // lifetime earnings
  pendingPayoutUsd      Float     @default(0) // earnings not yet paid out
  status                String    @default("active") // active | suspended | paid_out
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  payouts      AffiliatePayout[]
  referrals    AffiliateReferral[]

  @@index([affiliateCode])
  @@index([status])
}

model AffiliateReferral {
  id                String    @id @default(cuid())
  affiliateId       String
  referredUserId    String    @unique  // the user who was referred
  status            String    @default("registered") // registered | active | churned
  firstPaymentAt    DateTime? // when the referred user first paid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  affiliate         Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([status])
  @@index([referredUserId])
}

model AffiliatePayout {
  id                String    @id @default(cuid())
  affiliateId       String
  referredUserId    String    // the user whose payment generated this commission
  amountUsd         Float     // commission amount in USD
  percentageApplied Float     // e.g. 10.0, 20.0, 30.0, 40.0, 50.0
  sourceAmountUsd   Float     // the original payment amount that generated this commission
  status            String    @default("pending") // pending | paid | cancelled
  stripeTransferId  String?   // Stripe transfer ID once paid out
  paidAt            DateTime?
  createdAt         DateTime  @default(now())

  affiliate         Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([status])
  @@index([createdAt])
}

model TokenUsageLog {
  id               String   @id @default(cuid())
  userId           String?  // nullable for anonymous scans
  projectId        String?  // nullable
  analysisId       String?  // nullable
  agentName        String   // e.g. "master_director", "competitor_analyst"
  modelUsed        String   // e.g. "gpt-4o", "claude-3-5-sonnet", "deepseek-v3"
  promptTokens     Int
  completionTokens Int
  costUsd          Float    // calculated cost: (prompt * model_price) + (completion * model_price)
  createdAt        DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  analysis Analysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([analysisId])
  @@index([agentName])
  @@index([modelUsed])
  @@index([createdAt])
  // Composite indexes for enterprise analytics (from SQL spec)
  @@index([userId, createdAt])       // idx_logs_user_time: per-user time-series for Superadmin dashboard
  @@index([agentName, modelUsed])    // idx_logs_agent_model: agent performance + cost per model
}
